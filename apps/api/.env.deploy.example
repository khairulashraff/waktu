# Deploy-time knobs for `node scripts/deploy-build.mjs`.
# Copy to .env.deploy and edit as needed. Every value has a default, so an empty
# file (or no file at all) still produces a working stack — override only what
# differs for your target host.

# Registry the image is pushed to and the target host pulls from.
WAKTU_REGISTRY=localhost:5000

# Target CPU architecture. arm64 for many small/ARM boxes; linux/amd64 for x86.
WAKTU_PLATFORM=linux/arm64

# Host port that maps to the API container's :3000.
WAKTU_PORT=3000

# Optional — Unsplash API access key to enable the /gambar wallpaper endpoint.
# Get one at https://unsplash.com/developers ; baked into the deployed stack.
UNSPLASH_ACCESS_KEY=
