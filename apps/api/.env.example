# Copy to `.env` (git-ignored) for local `pnpm dev:api`. api.js loads it at startup.
# In Docker/deploy these come from the container environment instead.

# Unsplash API key — enables the /gambar wallpaper endpoint.
# Get one at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Redis connection (defaults to redis://localhost:6379 when unset).
# REDIS_URL=redis://localhost:6379

# Listen port (defaults to 3000 when unset).
# PORT=3000
