# Copy to .env.deploy (git-ignored) and set your deployment target.
# Consumed by deploy.sh / deploy.bat to build and ship the client to a remote host.

# API base URL baked into the client build. MUST be reachable from the device
# running the client (not localhost, unless the API runs on that same device).
VITE_API_BASE=http://your-api-host:3000

# SSH user on the target host.
REMOTE_USER=root
# Target host (hostname or IP) reachable over SSH.
REMOTE_HOST=raspberrypi.local
# Directory on the target where the unpacked app is written.
REMOTE_APP_DIR=/opt/waktu/client
# supervisor program name used to (re)start the app on the target.
SUPERVISOR_SERVICE_NAME=waktu-client
